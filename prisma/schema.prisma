// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
  output     = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Collection {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  createdAt DateTime @default(now())
}

model Download {
  id        Int      @id @default(autoincrement())
  title     String
  filePath  String   @unique
  type      String // "audio" o "video"
  channel   String?
  duration  String?
  thumbnail String?
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  password            String
  isAdmin             Boolean              @default(false)
  subscriptionStatus  String               @default("free") // "free" o "active"
  subscriptionEndsAt  DateTime?
  downloads           Download[]
  payments            Payment[]
  createdAt           DateTime             @default(now())
  userAccess          UserAccess?

  @@index([isAdmin])
}

model UserAccess {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  daysAllowed     Int      @default(30)
  expiresAt       DateTime
  downloadEnabled Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Payment {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Float    @default(0)
  currency  String   @default("ARS")
  note      String?
  status    String   @default("pending") // "pending" o "confirmed"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  createdAt DateTime @default(now())
}

// Agrega un modelo para almacenar los logs de la aplicación
model Log {
  id        Int      @id @default(autoincrement())
  message   String
  level     String
  createdAt DateTime @default(now())
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
}

// Agrega un modelo para almacenar las claves de API
model ApiKey {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  createdAt DateTime @default(now())
}
